# ══════════════════════════════════════════════
#   ANA AGENT — Variables de Entorno
#   Copia este archivo como .env y completa los valores
# ══════════════════════════════════════════════

# ── SERVIDOR ──────────────────────────────────
PORT=3000
NODE_ENV=production

# ── RETELL AI ─────────────────────────────────
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxx
RETELL_WEBHOOK_SECRET=your_webhook_secret_here

# ── TWILIO ────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+18295551234

# ── GOOGLE CALENDAR ───────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=https://tu-dominio.com/auth/google/callback
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALENDAR_ID=primary

# ── CONSULTORIO ───────────────────────────────
DOCTOR_NAME=Dr. García
DOCTOR_SPECIALTY=Medicina General
CLINIC_NAME=Consultorio Dr. García
CLINIC_PHONE=+18091234567
EMERGENCY_FORWARD_NUMBER=+18091234567
APPOINTMENT_DURATION_MINUTES=30
WORKING_HOURS_START=08:00
WORKING_HOURS_END=18:00
WORKING_DAYS=1,2,3,4,5
TIMEZONE=America/Santo_Domingo

# ── NOTIFICACIONES (opcional) ─────────────────
WHATSAPP_NOTIFY=false
